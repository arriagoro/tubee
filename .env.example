# Tubee — Environment Variables
# Copy this file to .env and fill in your keys

# ─── AI (Claude) ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Video Generation APIs (optional — set at least one to enable AI generation)
# Get keys from:
#   Runway ML:  https://dev.runwayml.com/
#   Kling AI:   https://klingai.com/
#   Luma Labs:  https://lumalabs.ai/

RUNWAY_API_KEY=your-runway-key
KLING_API_KEY=your-kling-key
LUMA_API_KEY=your-luma-key

# ─── Notes ────────────────────────────────────────────────────────────────────
# Video upscaling works locally with no API key (uses FFmpeg or Real-ESRGAN)
# The edit feature only requires ANTHROPIC_API_KEY
# Generation requires at least one video generation API key above
